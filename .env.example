# --- HTTP (Express, production / Docker) ---
PORT=3000
NODE_ENV=development

# --- Vite dev server (apps/client) ---
CLIENT_DEV_PORT=5173

# Bind address for Vite (`true` = all interfaces, same as 0.0.0.0)
CLIENT_DEV_HOST=0.0.0.0

# --- Static build (optional override) ---
# Absolute or repo-relative path to Vite `dist` when starting the server from repo root.
# Default when unset: apps/client/dist
# CLIENT_DIST_PATH=apps/client/dist

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=game-rpg
